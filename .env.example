# Шаблон env-переменных для модуля /social в CS Dashboard.
# Реальные значения живут в env Dashboard прода (Vercel / .env на VPS).
# Этот файл — справочник какие переменные нужны.

# --- Supabase (наследуется от Dashboard, не дублировать локально) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGc...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Encryption (наследуется от Dashboard) ---
# 32-байтный hex для AES-256-GCM. Используется для шифрования TG/IG tokens в БД.
# ENCRYPTION_KEY=64_hex_characters_here

# --- Telegram Bot ---
# Токен бота, хранится в plaintext только в env прода. В БД — зашифрованный.
# Бот должен быть админом канала @traffnews с правом Post Messages.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVwxyz_-

# Каналы для постинга (chat_id или @username).
# Для приватных каналов — chat_id (-100xxxxxxxxxx).
TELEGRAM_CHANNEL_ID=@traffnews

# Optional: chat_id админ-чата для error alerts (рекомендую — отдельный приватный чат)
TELEGRAM_ADMIN_CHAT_ID=

# --- Instagram Graph API ---
# Long-lived access token (60 дней). Refresh через cron.
INSTAGRAM_ACCESS_TOKEN=EAA...

# Instagram Business Account ID (числовой)
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841...

# Facebook Page ID к которой привязан IG
FACEBOOK_PAGE_ID=1234567890

# Facebook App credentials (для token refresh)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- OpenClaw Gateway (post-MVP, для AI-помощника в v3) ---
# Только если включаем "rewrite caption" кнопку в редакторе
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:xxxx/v1/chat/completions
# OPENCLAW_AUTH_TOKEN=

# --- RSS Sources (для Radar tab, v2) ---
# Может храниться в БД (social_rss_sources таблица), env не обязателен
# RSS_DEFAULT_SOURCES=https://traffnews.com/feed/
